# Feishu credentials
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# Workspace / runtime
CODING_CLAW_WORKSPACE_ROOT=D:/coding-claw-workspaces
CODING_CLAW_LANGUAGE=zh-CN
CLAUDE_MODEL=claude-sonnet-4-6
CODING_CLAW_CLAUDE_PATH=C:/Users/your-user/.local/bin/claude.exe
CLAUDE_CODE_GIT_BASH_PATH=D:\\DEVELOP\\Git\\usr\\bin\\bash.exe
CODING_CLAW_SHELL=bash

# Optional script-managed runtime files
# CODING_CLAW_LOG_FILE=.runtime/logs/bridge.log
# CODING_CLAW_PID_FILE=.runtime/bridge.pid

# Optional agent teams
CODING_CLAW_ENABLE_AGENT_TEAMS=1
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# Model alias mapping for /agent model
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_DEFAULT_SONNET_1M_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_OPUS_1M_MODEL=claude-opus-4-6

# Local proxy / gateway mode
ANTHROPIC_BASE_URL=http://127.0.0.1:15721
ANTHROPIC_AUTH_TOKEN=your_proxy_auth_token
