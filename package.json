{
  "name": "coding-claw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "dev": "pnpm --filter @coding-claw/bridge dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:repo-hygiene": "bash -lc 'tracked=$(git ls-files | grep -E \"(^|/)dist/\" || true); if [ -n \"$tracked\" ]; then printf \"Tracked build artifacts are not allowed:\n%s\n\" \"$tracked\"; exit 1; fi'"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^24.5.2",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.29.1",
    "vitest": "^3.2.4"
  }
}
