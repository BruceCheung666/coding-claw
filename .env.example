# Cross-platform minimal example.
# For deployment-oriented templates, see:
# - docs/deployment/env.official.example
# - docs/deployment/env.proxy.example

# Required: Feishu / Lark application credentials
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# Optional: Claude model override
CLAUDE_MODEL=claude-sonnet-4-6

# Optional: workspace root used by the bridge
# Default: <repo>/.claude/workspaces
CODING_CLAW_WORKSPACE_ROOT=/absolute/path/to/workspaces

# Optional: default bridge language
# Default: zh-CN
CODING_CLAW_LANGUAGE=zh-CN

# Optional: explicit Claude Code executable path
# If omitted, runtime falls back to its default resolution behavior
CODING_CLAW_CLAUDE_PATH=/absolute/path/to/claude

# Optional: explicit Git Bash path for Windows deployments
# CLAUDE_CODE_GIT_BASH_PATH=C:\\Path\\To\\Git\\usr\\bin\\bash.exe

# Optional: shell executable for persistent /shell sessions
# Default: /bin/sh
CODING_CLAW_SHELL=/bin/bash

# Optional: preferred bridge-side switch for Agent Teams
CODING_CLAW_ENABLE_AGENT_TEAMS=0

# Optional: upstream-compatible / troubleshooting flag for Claude Code team feature gate
# Final Team tool availability still depends on what the upstream init toolset returns
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=0

# Optional: model alias customization used by control commands
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_DEFAULT_SONNET_1M_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_OPUS_1M_MODEL=claude-opus-4-6
# ANTHROPIC_CUSTOM_MODEL_OPTION=partner/custom-model

# Optional: disable 1M context related option handling
# CLAUDE_CODE_DISABLE_1M_CONTEXT=0
